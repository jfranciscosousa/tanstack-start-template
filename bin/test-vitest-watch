#!/bin/sh

# Vitest watch mode script
# This script runs unit tests in watch mode

set -e  # Exit on error

# Test scripts require .env.test — skipped in CI where env vars are set directly
if [ -z "${CI:-}" ]; then
    if [ ! -f ".env.test" ]; then
        echo "❌ .env.test not found. Copy .env.test.sample to .env.test and configure it."
        exit 1
    fi
    if [ -n "${ENV_LOADED:-}" ] && [ "$ENV_LOADED" != ".env.test" ]; then
        echo "❌ Environment '$ENV_LOADED' already loaded. Test scripts require .env.test."
        exit 1
    fi
fi
if [ -f ".env.test" ]; then
    ENV_FILE=.env.test . bin/load-env
fi

echo "👀 Running unit tests in watch mode..."

migrate_output=$(pnpm drizzle-kit migrate 2>&1) || { echo "$migrate_output" >&2; exit 1; }

# Run Vitest in watch mode
NODE_ENV=test pnpm vitest "$@"

echo "✅ Vitest watch mode ended"