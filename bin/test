#!/bin/sh

# Test script
# This script runs all tests (unit tests and e2e tests)

set -e  # Exit on error

# Test scripts require .env.test — skipped in CI where env vars are set directly
if [ -z "${CI:-}" ]; then
    if [ ! -f ".env.test" ]; then
        echo "❌ .env.test not found. Copy .env.test.sample to .env.test and configure it."
        exit 1
    fi
    if [ -n "${ENV_LOADED:-}" ] && [ "$ENV_LOADED" != ".env.test" ]; then
        echo "❌ Environment '$ENV_LOADED' already loaded. Test scripts require .env.test."
        exit 1
    fi
fi
if [ -f ".env.test" ]; then
    ENV_FILE=.env.test . bin/load-env
fi

echo "🧪 Running all tests..."

echo "📋 Running unit tests with Vitest..."
./bin/test-vitest

echo "🎭 Running end-to-end tests..."
./bin/test-e2e

echo "✅ All tests completed successfully!"