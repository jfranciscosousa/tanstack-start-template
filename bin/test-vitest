#!/bin/sh

# Vitest unit test script
# This script runs unit tests with Vitest

set -e  # Exit on error

# Test scripts require .env.test — skipped in CI where env vars are set directly
if [ -z "${CI:-}" ]; then
    if [ ! -f ".env.test" ]; then
        echo "❌ .env.test not found. Copy .env.test.sample to .env.test and configure it."
        exit 1
    fi
    if [ -n "${ENV_LOADED:-}" ] && [ "$ENV_LOADED" != ".env.test" ]; then
        echo "❌ Environment '$ENV_LOADED' already loaded. Test scripts require .env.test."
        exit 1
    fi
fi
if [ -f ".env.test" ]; then
    ENV_FILE=.env.test . bin/load-env
fi

echo "🧪 Running unit tests with Vitest..."

# Drop all tables so drizzle-kit push sees a clean DB (no rename prompts)
node --input-type=module << 'EOF'
import postgres from "postgres";
const sql = postgres(process.env.DATABASE_URL);
await sql`DROP SCHEMA public CASCADE`;
await sql`CREATE SCHEMA public`;
await sql.end();
EOF

pnpm drizzle-kit push

# Run Vitest in run mode (non-watch)
NODE_ENV=test pnpm vitest run "$@"

echo "✅ Unit tests completed successfully!"