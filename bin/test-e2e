#!/bin/sh

# End-to-end test script
# This script runs Playwright e2e tests with database setup

set -e  # Exit on error

# Test scripts must use .env.test — refuse to run with any other environment
if [ ! -f ".env.test" ]; then
    echo "❌ .env.test not found. Copy .env.test.sample to .env.test and configure it."
    exit 1
fi
if [ -n "${ENV_LOADED:-}" ] && [ "$ENV_LOADED" != ".env.test" ]; then
    echo "❌ Environment '$ENV_LOADED' already loaded. Test scripts require .env.test."
    exit 1
fi
ENV_FILE=.env.test . bin/load-env

bin/test-e2e-setup

echo "🎭 Running end-to-end tests..."

pnpm playwright test "$@"

echo "✅ End-to-end tests completed successfully!"
